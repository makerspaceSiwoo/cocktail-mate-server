# 커밋되는 예시(public). 실제 값은 .env(커밋 금지)에 작성한다. 소셜 로그인 전용.
# 토큰 만료·로그레벨 등 고정 상수는 app/core/config.py 기본값을 쓴다.

# local | production  (production 만 CORS 를 엄격 제한)
APP_ENV=local

# 런타임 DB 접속(cm_app). 프로덕션(OCI 인스턴스)은 host 만 host.docker.internal 로.
DATABASE_URL=postgresql+psycopg2://cm_app:<CM_APP_PASSWORD>@152.69.225.226:5432/cocktail_mate

# 허용 프론트 origin (콤마 구분, CSRF allowlist 겸용). 로컬은 비워도 됨(localhost 자동 허용).
# host 가 다르면(www ↔ api) 교차출처라 반드시 명시해야 한다.
CORS_ORIGINS=            # 예) https://www.cocktail-mate.com,http://localhost:3000

# JWT 서명키 (openssl rand -hex 32). 프로덕션 필수 — 안 바꾸면 토큰 위조 가능.
SECRET_KEY=<openssl rand -hex 32>

# 소셜 콜백 성공 후 리다이렉트할 프론트 (끝 슬래시 없이). 로컬은 http://localhost:3000
FRONTEND_URL=https://www.cocktail-mate.com

# 쿠키 secure — 소셜 콜백(Origin 없음)의 정적 fallback. 프로덕션 true, 로컬 false.
COOKIE_SECURE=true

# 카카오 (동의항목 미요청 — 유저 id만 사용). REDIRECT_URI 는 콘솔 등록값과 정확히 일치해야 한다.
KAKAO_CLIENT_ID=<KAKAO_REST_API_KEY>
KAKAO_CLIENT_SECRET=<KAKAO_CLIENT_SECRET>
KAKAO_REDIRECT_URI=https://api.cocktail-mate.com/auth/kakao/callback   # 로컬: http://localhost:8000/auth/kakao/callback
