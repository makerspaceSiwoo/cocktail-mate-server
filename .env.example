# 이 파일은 커밋됩니다. 실제 비밀값은 .env(커밋 금지)에 작성하세요.
#   로컬: cp .env.example .env  (아래 기본값 그대로 동작)
#   프로덕션(Oracle): STORAGE_* 를 Oracle Object Storage 값으로 교체 (DEPLOY.md 참고)

# ---- App ----
APP_ENV=local

# ---- Database (PostgreSQL + pgvector) ----
POSTGRES_DB=cocktail_mate
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change_me
# 컨테이너 내부에서는 호스트명이 db(컴포즈 서비스명)
DATABASE_URL=postgresql+psycopg2://app_user:change_me@db:5432/cocktail_mate

# ---- Object Storage (S3 compatible) ----
# 로컬은 MinIO 기본값. 프로덕션은 아래 주석 형태로 교체.
#   STORAGE_ENDPOINT=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
#   STORAGE_PUBLIC_BASE_URL=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com/<bucket>
#   STORAGE_ACCESS_KEY / STORAGE_SECRET_KEY = Oracle Customer Secret Key (Access/Secret)
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=ap-chuncheon-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=cocktail-images
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/cocktail-images
