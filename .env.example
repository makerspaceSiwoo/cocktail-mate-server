# 이 파일은 커밋됩니다(public 레포). 실제 값은 .env(커밋 금지)에 작성하세요.
#   사용법: cp .env.example .env  후, 아래 <...> 부분만 실제 값으로 채우면 됩니다.
#
# ───────────── 내가 채워야 할 값 (<...>) ─────────────
#   DATABASE_URL 의 <CM_APP_PASSWORD>   : api 런타임 계정 cm_app 비밀번호 (DBeaver용 cm_dml 아님!)
#   STORAGE_* (옵션 A: Oracle 사용 시)   : <NAMESPACE> + 액세스/시크릿 키
#   (로컬에서 스토리지가 필요 없으면 옵션 B의 MinIO를 쓰면 채울 게 없음)
# 나머지(APP_ENV, STORAGE_REGION, STORAGE_BUCKET 등)는 기본값 그대로 두세요.

# ---- App ----
# local | development | production  (production만 CORS_ORIGINS로 origin 엄격 제한)
APP_ENV=local

# production에서 허용할 프론트 origin (콤마 구분). 개발 중엔 비워둠.
#   프론트 origin 3개를 등록한다: 로컬 개발 / 테스트(preview) / 프로덕션 Vercel.
#   예) CORS_ORIGINS=https://cocktail-mate.vercel.app,https://cocktail-mate-preview.vercel.app,http://localhost:3000
#   이 목록은 CSRF 방어(app/core/csrf.py)의 Origin allowlist 로도 재사용된다.
CORS_ORIGINS=

# ---- Database (OCI 원격 개발 DB — 로컬 DB 없음) ----
# api가 OCI 공인 IP의 개발 DB에 직접 접속한다. 계정은 cm_app(런타임 전용, DDL 불가).
# [로컬 개발] 공인 IP로:
DATABASE_URL=postgresql+psycopg2://cm_app:<CM_APP_PASSWORD>@152.69.225.226:5432/cocktail_mate
# [프로덕션 = OCI 인스턴스의 .env] 호스트만 host.docker.internal 로 (자기 공인 IP hairpin 불가):
#   DATABASE_URL=postgresql+psycopg2://cm_app:<CM_APP_PASSWORD>@host.docker.internal:5432/cocktail_mate

# ---- Object Storage (이미지 저장, S3 호환) ----
# [옵션 A] Oracle Object Storage (실제/프로덕션) — <NAMESPACE>와 키만 채우면 됨:
STORAGE_ENDPOINT=https://<NAMESPACE>.compat.objectstorage.ap-chuncheon-1.oraclecloud.com
STORAGE_REGION=ap-chuncheon-1
STORAGE_ACCESS_KEY=<ORACLE_ACCESS_KEY>
STORAGE_SECRET_KEY=<ORACLE_SECRET_KEY>
STORAGE_BUCKET=cocktail-images
STORAGE_PUBLIC_BASE_URL=https://<NAMESPACE>.compat.objectstorage.ap-chuncheon-1.oraclecloud.com/cocktail-images
#
# [옵션 B] 로컬 MinIO (오프라인, 실제 키 불필요) — 위 STORAGE_* 6줄을 아래로 교체하고
#   `docker compose --profile local-storage up -d` 로 minio를 함께 띄운다:
#     STORAGE_ENDPOINT=http://minio:9000
#     STORAGE_REGION=ap-chuncheon-1
#     STORAGE_ACCESS_KEY=minioadmin
#     STORAGE_SECRET_KEY=minioadmin
#     STORAGE_BUCKET=cocktail-images
#     STORAGE_PUBLIC_BASE_URL=http://localhost:9000/cocktail-images

# ---- Auth (JWT 쿠키 인증) ----
# JWT 서명 키 — 반드시 교체! 생성: openssl rand -hex 32
SECRET_KEY=<openssl rand -hex 32>
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
EMAIL_VERIFY_EXPIRE_HOURS=24
# 매직 링크가 여는 프론트 주소 (소셜 콜백 후 리다이렉트도 여기로)
FRONTEND_URL=http://localhost:3000
# 쿠키 flag(secure/samesite)는 요청 Origin 기준으로 동적 결정된다:
#   localhost origin → SameSite=Lax(비 Secure), 배포 cross-site origin → SameSite=None; Secure.
# 아래 정적 값은 이제 Origin 헤더가 없는 요청(카카오 콜백 등 top-level 리다이렉트)의 fallback 으로만 쓰인다.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ---- Mail (Resend HTTP API) ----
# MAIL_API_KEY 가 비어 있으면 개발용 콘솔 백엔드 — 매직 링크를 서버 로그로만 출력한다.
MAIL_API_KEY=
MAIL_FROM=no-reply@cocktail-mate.local

# ---- 소셜 로그인 (카카오; provider 확장은 KakaoProvider 참고) ----
KAKAO_CLIENT_ID=<KAKAO_REST_API_KEY>
KAKAO_CLIENT_SECRET=<KAKAO_CLIENT_SECRET>
KAKAO_REDIRECT_URI=http://localhost:8000/auth/kakao/callback

# ---- ngrok (선택, 로컬 외부 터널) ----
# 평소 비워둠. 외부에서 로컬 api를 호출해볼 때만 토큰 채우고 `--profile tunnel`로 기동.
#   토큰: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
