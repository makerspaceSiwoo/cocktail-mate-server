# 커밋되는 예시(public). 실제 값은 .env / .env.local(둘 다 커밋 금지)에 작성한다. 소셜 로그인 전용.
#
# make up 은 env 파일을 '택일'한다 (병합 아님):
#   .env.local 있으면 → .env.local 만,  없으면 → .env,  둘 다 없으면 → 에러.
#   ⇒ 로컬 개발자는 .env.local 하나만, 배포 서버는 .env 하나만 두면 된다.
# 각 파일은 self-contained — 아래 모든 키를 다 채워야 한다(상속 없음).
#   - .env.local : 로컬값 (APP_ENV=local, COOKIE_SECURE=false, localhost redirect/front …)
#   - .env       : 상용값 (APP_ENV=production, COOKIE_SECURE=true, 배포 도메인 …)
# 토큰 만료·로그레벨 등 고정 상수는 app/core/config.py 기본값을 쓴다.

# ===== 공통 키 (아래를 .env / .env.local 각각에 self-contained 로 작성) =====
# 값은 예시로 '상용(.env)' 기준. 로컬(.env.local)은 주석의 [local] 값으로 바꾼다.

# local | production  (production 만 CORS 를 엄격 제한)   ▷ [local] APP_ENV=local
APP_ENV=production

# 런타임 DB 접속 — cm_app 계정 (SELECT/INSERT/UPDATE/DELETE, DDL 불가).
# 이 파일(APP_ENV_FILE)은 API 런타임 컨테이너에만 주입된다.
# Alembic(DDL)은 별도 ALEMBIC_DATABASE_URL(cm_admin)을 사용하며,
# MIGRATION_ENV_FILE 로 마이그레이션 컨테이너에만 주입된다 — API 컨테이너에는 절대 존재하지 않는다.
# (설정 방법은 docs/monorepo-cicd-runbook.md Section A 참조)
DATABASE_URL=postgresql+psycopg2://cm_app:<CM_APP_PASSWORD>@<OCI_HOST>:5432/cocktail_mate

# 주 허용 방식: 이 도메인의 모든 https 서브도메인(+apex)을 자동 허용.
# test./www./dev. 등 새 서브도메인을 매번 등록할 필요가 없다. CORS·CSRF 공통 적용.
CORS_ORIGIN_DOMAIN=cocktail-mate.com

# (선택) 위 도메인에 속하지 않는 예외 origin 만 콤마로 추가.
#   예) 로컬 개발용 http://localhost:3000, 외부 프리뷰 도메인 등.
# cocktail-mate.com 서브도메인/apex 는 CORS_ORIGIN_DOMAIN 이 이미 커버하므로
# 여기 넣지 않아도 된다(비워도 됨). CSRF allowlist 겸용.
CORS_ORIGINS=

# JWT 서명키 (openssl rand -hex 32). 프로덕션 필수 — 안 바꾸면 토큰 위조 가능.
SECRET_KEY=<openssl rand -hex 32>

# 소셜 콜백 성공 후 리다이렉트 주소 (끝 슬래시 없이).
#   ▷ [local] FRONTEND_URL=http://localhost:8000/docs  (프론트 함께 띄우면 http://localhost:3000)
FRONTEND_URL=https://cocktail-mate.com

# 쿠키 secure — 소셜 콜백(Origin 없음)의 정적 fallback.   ▷ [local] COOKIE_SECURE=false
COOKIE_SECURE=true

# 카카오 (동의항목 미요청 — 유저 id만 사용). REDIRECT_URI 는 콘솔 등록값과 정확히 일치해야 한다.
# 로컬 콜백도 카카오 콘솔에 Redirect URI 로 등록돼 있어야 한다.
KAKAO_CLIENT_ID=<KAKAO_REST_API_KEY>
KAKAO_CLIENT_SECRET=<KAKAO_CLIENT_SECRET>
#   ▷ [local] KAKAO_REDIRECT_URI=http://localhost:8000/auth/kakao/callback
KAKAO_REDIRECT_URI=https://api.cocktail-mate.com/auth/kakao/callback

# ===== 요약 =====
# 로컬 개발자: 위 키 전부를 .env.local 에 넣되 ▷[local] 표시 4개만 로컬값으로. (그리고 make up)
# 배포 서버:   위 키 전부를 .env 에 상용값으로.
# 둘 다 git-ignore(.env*) — .env.example 만 커밋된다.
