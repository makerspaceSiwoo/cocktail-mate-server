# 이 파일은 커밋됩니다. 실제 비밀값은 .env(커밋 금지)에 작성하세요.
# 로컬 개발자는 팀 채널(비공개)에서 완성된 .env를 받아 그대로 쓰면 됩니다 — docs/ONBOARDING.md 참고.
#   프로덕션(Oracle): STORAGE_* 를 Oracle Object Storage 값으로 교체 (DEPLOY.md 참고)

# ---- App ----
# APP_ENV: local | development | production
#   - local / development : localhost 모든 포트를 CORS 자동 허용 (개발 편의)
#   - production          : 아래 CORS_ORIGINS 에 명시한 origin만 허용 (엄격)
APP_ENV=local

# production 에서 허용할 프론트 origin (콤마 구분). 개발 환경에선 비워둬도 된다.
#   예) CORS_ORIGINS=https://cocktail-mate-front.vercel.app
CORS_ORIGINS=

# ---- Database (OCI 원격 개발 DB — PostgreSQL + pgvector) ----
# 로컬 DB 없음: api가 OCI 공인 IP의 개발 DB에 직접 접속한다.
# 실제 IP/비밀번호는 팀 채널의 .env에만 존재 (public 레포이므로 여기엔 placeholder만).
# 계정: cm_app (런타임 전용, DDL 불가). 스키마/운영은 cocktail-mate-db 레포 담당.
# 프로덕션(.env on OCI)은 호스트만 host.docker.internal 로 (자기 공인 IP hairpin 불가):
#   DATABASE_URL=postgresql+psycopg2://cm_app:<password>@host.docker.internal:5432/cocktail_mate
DATABASE_URL=postgresql+psycopg2://cm_app:<password>@<OCI_PUBLIC_IP>:5432/cocktail_mate

# ---- Object Storage (S3 compatible) ----
# 팀 .env는 Oracle Object Storage 값. 오프라인 작업 시엔 minio 프로필을 띄우고 아래로 교체:
#   docker compose --profile local-storage up -d
#   STORAGE_ENDPOINT=http://minio:9000
#   STORAGE_ACCESS_KEY=minioadmin / STORAGE_SECRET_KEY=minioadmin
#   STORAGE_PUBLIC_BASE_URL=http://localhost:9000/cocktail-images
STORAGE_ENDPOINT=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
STORAGE_REGION=ap-chuncheon-1
STORAGE_ACCESS_KEY=<oracle-customer-secret-access-key>
STORAGE_SECRET_KEY=<oracle-customer-secret-key>
STORAGE_BUCKET=cocktail-images
STORAGE_PUBLIC_BASE_URL=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com/cocktail-images

# ---- ngrok (선택, 로컬 개발용 외부 터널) ----
# 로컬 개발 중 외부에서 API를 호출해보고 싶을 때만 사용한다.
#   토큰 발급: https://dashboard.ngrok.com/get-started/your-authtoken
#   기동: docker compose --profile tunnel up -d   /   URL: docker compose logs ngrok
NGROK_AUTHTOKEN=
