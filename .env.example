# 커밋되는 예시 파일(public 레포). 실제 값은 .env(커밋 금지)에 작성한다.
#   여기엔 "환경마다 실제로 채우는 값(시크릿·환경별 설정)"만 둔다.
#   토큰 만료·쿠키 정책·로그레벨 등 고정 상수는 app/core/config.py 기본값을 쓴다.
#   소셜 로그인 전용 — 이메일/비밀번호/메일(SMTP) 설정 없음.

# ==== App ====
APP_ENV=local            # local | production  (production 만 CORS 를 엄격 제한)

# ==== Database ====   ★ cm_app 비밀번호(런타임 계정 — DBeaver용 cm_dml 아님)
DATABASE_URL=postgresql+psycopg2://cm_app:<CM_APP_PASSWORD>@152.69.225.226:5432/cocktail_mate
#   [프로덕션 = OCI 인스턴스] 호스트만 host.docker.internal 로:
#   DATABASE_URL=postgresql+psycopg2://cm_app:<CM_APP_PASSWORD>@host.docker.internal:5432/cocktail_mate

# ==== Object Storage (S3 호환: 프로덕션 Oracle Object Storage / 로컬 MinIO) ====
STORAGE_ENDPOINT=https://<네임스페이스>.compat.objectstorage.<region>.oraclecloud.com
STORAGE_REGION=ap-chuncheon-1
STORAGE_ACCESS_KEY=<S3_ACCESS_KEY>
STORAGE_SECRET_KEY=<S3_SECRET_KEY>
STORAGE_BUCKET=cocktail-images
STORAGE_PUBLIC_BASE_URL=https://<네임스페이스>.compat.objectstorage.<region>.oraclecloud.com/cocktail-images

# ==== CORS / 허용 프론트 origin ====  (콤마 구분, CSRF allowlist 겸용)
# 로컬은 비워도 됨(localhost 자동 허용). 프로덕션은 프론트 주소 등록 필수.
# ※ 같은 상위도메인이어도 host 가 다르면(www ↔ api) 교차출처라 CORS 에 명시해야 한다.
CORS_ORIGINS=            # 예) https://www.cocktail-mate.com,http://localhost:3000

# ==== JWT 서명키 ====   ★ 프로덕션 필수 — 안 바꾸면 토큰 위조 가능
SECRET_KEY=<openssl rand -hex 32>

# ==== 소셜 콜백 성공 후 리다이렉트할 프론트 주소 ====  (환경마다 다름, 끝 슬래시 없이)
FRONTEND_URL=https://www.cocktail-mate.com     # 로컬 테스트는 http://localhost:3000

# ==== 쿠키 ====  Origin 없는 요청(소셜 콜백 top-level 리다이렉트)의 정적 fallback.
# 프로덕션(https) true, 로컬(http) false.
COOKIE_SECURE=true

# ==== 소셜 로그인 (카카오) ====  동의항목 미요청 — 유저 id만 받고 닉네임은 서버 기본값.
KAKAO_CLIENT_ID=<KAKAO_REST_API_KEY>
KAKAO_CLIENT_SECRET=<KAKAO_CLIENT_SECRET>
KAKAO_REDIRECT_URI=https://api.cocktail-mate.com/auth/kakao/callback     # 로컬: http://localhost:8000/auth/kakao/callback

# ==== 소셜 로그인 (구글; 확장용 — 활성화 전까지 비워둠) ====
# GOOGLE_CLIENT_ID=<GOOGLE_CLIENT_ID>
# GOOGLE_CLIENT_SECRET=<GOOGLE_CLIENT_SECRET>
# GOOGLE_REDIRECT_URI=https://api.cocktail-mate.com/auth/google/callback
