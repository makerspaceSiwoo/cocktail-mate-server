# 커밋되는 예시 파일(public 레포). 실제 값은 .env(커밋 금지)에 작성한다.
#   여기엔 "환경마다 실제로 채우는 값(시크릿·환경별 설정)"만 둔다.
#   토큰 만료·쿠키 정책·로그레벨 등 고정 상수는 app/core/config.py 기본값을 쓴다.

# ==== App ====
APP_ENV=local            # local | production  (production 만 CORS 를 엄격 제한)

# ==== Database ====   ★ cm_app 비밀번호(런타임 계정 — DBeaver용 cm_dml 아님)
DATABASE_URL=postgresql+psycopg2://cm_app:<CM_APP_PASSWORD>@152.69.225.226:5432/cocktail_mate
#   [프로덕션 = OCI 인스턴스] 호스트만 host.docker.internal 로:
#   DATABASE_URL=postgresql+psycopg2://cm_app:<CM_APP_PASSWORD>@host.docker.internal:5432/cocktail_mate

# ==== CORS / 허용 프론트 origin ====  (콤마 구분, CSRF allowlist 겸용)
# 로컬은 비워도 됨(localhost 자동 허용). 프로덕션은 프론트 주소 등록 필수.
CORS_ORIGINS=            # 예) https://cocktail-mate.vercel.app,http://localhost:3000

# ==== JWT 서명키 ====   ★ 프로덕션 필수 — 안 바꾸면 토큰 위조 가능
SECRET_KEY=<openssl rand -hex 32>

# ==== 매직 링크가 여는 프론트 주소 ====  (환경마다 다름, 끝 슬래시 없이)
FRONTEND_URL=https://cocktail-mate.vercel.app     # 로컬 테스트는 http://localhost:3000

# ==== 메일 (Resend HTTP API) ====  SMTP 제거 → Resend(선택) 또는 콘솔.
# MAIL_API_KEY 가 비어 있으면 콘솔모드(매직 링크를 서버 로그로만 출력). 실제 발송 시에만 채움.
# MAIL_API_KEY=<RESEND_API_KEY>
MAIL_FROM=no-reply@cocktail-mate.local

# ==== 소셜 로그인 (카카오) ====
KAKAO_CLIENT_ID=<KAKAO_REST_API_KEY>
KAKAO_CLIENT_SECRET=<KAKAO_CLIENT_SECRET>
KAKAO_REDIRECT_URI=https://<API도메인>/auth/kakao/callback
