# 커밋되는 예시(public). 실제 값은 .env(커밋 금지)에 작성한다. 소셜 로그인 전용.
# 실행 기본값은 .env(배포 DB·배포 프론트 URL). 로컬 오버라이드는 opt-in:
#   make up        → .env 만 로드 (배포 DB·배포 프론트)
#   make up-local  → .env + .env.local(맨 아래 예시)로 localhost 값 오버라이드
# 토큰 만료·로그레벨 등 고정 상수는 app/core/config.py 기본값을 쓴다.

# ===== .env (기본/배포값) =====

# local | production  (production 만 CORS 를 엄격 제한)
APP_ENV=production

# 런타임 DB 접속(cm_app). 프로덕션(OCI 인스턴스)은 host 만 host.docker.internal 로.
DATABASE_URL=postgresql+psycopg2://cm_app:<CM_APP_PASSWORD>@152.69.225.226:5432/cocktail_mate

# 주 허용 방식: 이 도메인의 모든 https 서브도메인(+apex)을 자동 허용.
# test./www./dev. 등 새 서브도메인을 매번 등록할 필요가 없다. CORS·CSRF 공통 적용.
CORS_ORIGIN_DOMAIN=cocktail-mate.com

# (선택) 위 도메인에 속하지 않는 예외 origin 만 콤마로 추가.
#   예) 로컬 개발용 http://localhost:3000, 외부 프리뷰 도메인 등.
# cocktail-mate.com 서브도메인/apex 는 CORS_ORIGIN_DOMAIN 이 이미 커버하므로
# 여기 넣지 않아도 된다(비워도 됨). CSRF allowlist 겸용.
CORS_ORIGINS=

# JWT 서명키 (openssl rand -hex 32). 프로덕션 필수 — 안 바꾸면 토큰 위조 가능.
SECRET_KEY=<openssl rand -hex 32>

# 소셜 콜백 성공 후 리다이렉트할 프론트 (끝 슬래시 없이).
FRONTEND_URL=https://cocktail-mate.com

# 쿠키 secure — 소셜 콜백(Origin 없음)의 정적 fallback. 프로덕션 true.
COOKIE_SECURE=true

# 카카오 (동의항목 미요청 — 유저 id만 사용). REDIRECT_URI 는 콘솔 등록값과 정확히 일치해야 한다.
KAKAO_CLIENT_ID=<KAKAO_REST_API_KEY>
KAKAO_CLIENT_SECRET=<KAKAO_CLIENT_SECRET>
KAKAO_REDIRECT_URI=https://api.cocktail-mate.com/auth/kakao/callback

# ===== .env.local (로컬 오버라이드 — `make up-local` 일 때만 적용) =====
# 아래 4개만 .env.local 에 두면 나머지(시크릿/DB/CORS)는 .env 에서 상속된다.
#   APP_ENV=local
#   FRONTEND_URL=http://localhost:3000
#   COOKIE_SECURE=false
#   KAKAO_REDIRECT_URI=http://localhost:8000/auth/kakao/callback
