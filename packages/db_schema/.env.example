# 이 파일은 커밋됩니다. 실제 값은 .env(커밋 금지)에 작성하세요.

# Alembic / apply_roles 실행용 — 반드시 cm_admin (DDL 권한). 런타임 API에는 넣지 않는다.
ALEMBIC_DATABASE_URL=postgresql+psycopg2://cm_admin:<PASSWORD>@<OCI_PUBLIC_IP>:5432/cocktail_mate
# 런타임 API의 cm_app DATABASE_URL은 서버 .env에 존재하며 여기에는 넣지 않는다.

# docker/docker-compose.db.yml 용 (OCI 인스턴스에서만 필요)
# 새 볼륨 초기화 시 cm_admin이 이 값으로 생성된다(기존 볼륨이면 무시됨).
POSTGRES_DB=cocktail_mate
POSTGRES_USER=cm_admin
POSTGRES_PASSWORD=<PASSWORD>

# scripts/apply_roles.py 용 — cm_app/cm_dml 비밀번호 (settings가 여기서 읽음)
#   실행: python scripts/apply_roles.py   (또는 make roles)
CM_APP_PASSWORD=<PASSWORD>
CM_DML_PASSWORD=<PASSWORD>
