#!/bin/sh
# push 전: ① main 직접 push 차단 ② 브랜치명 검증 ③ ruff 포맷/린트 ④ build(컴파일) 테스트
# 활성화: make hooks  (git config core.hooksPath .githooks)

# ── 1) main 으로의 직접 push 차단 (PR 사용 강제) ──
while read -r _local_ref _local_sha remote_ref _remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    echo "❌ main 브랜치로 직접 push 할 수 없습니다. PR을 통해 머지하세요."
    exit 1
  fi
done

# ── 2) 브랜치명 검증 ──
branch=$(git rev-parse --abbrev-ref HEAD)
pattern='^(main|develop|(feat|fix|hotfix|chore|docs|refactor|test|other)/[a-z0-9._-]+)$'
if ! echo "$branch" | grep -qE "$pattern"; then
  echo "❌ 잘못된 브랜치명입니다: $branch"
  echo "   허용 패턴: main | develop | (feat|fix|hotfix|chore|docs|refactor|test|other)/소문자-슬러그"
  exit 1
fi

# ── 3) 포맷/린트 검사 (ruff) ──
if [ -x .venv/bin/ruff ]; then RUFF=".venv/bin/ruff";
elif command -v ruff >/dev/null 2>&1; then RUFF="ruff";
else
  echo "❌ ruff 없음 — 'pip install -r requirements-dev.txt' 후 다시 push 하세요."
  exit 1
fi
echo "🎨 포맷/린트 검사: ruff format --check . && ruff check . ..."
if ! "$RUFF" format --check .; then
  echo "❌ 포맷이 맞지 않습니다 — 'make format' 실행 후 커밋하세요."
  exit 1
fi
if ! "$RUFF" check .; then
  echo "❌ lint 실패 — 수정 후 다시 push 하세요."
  exit 1
fi
echo "✅ 포맷/린트 통과"

# ── 4) build 테스트 (Python 문법/컴파일 체크) ──
echo "🔧 build 체크: python -m compileall app ..."
if ! python3 -m compileall -q app; then
  echo "❌ 컴파일 실패 — 문법 오류를 수정하세요."
  exit 1
fi
echo "✅ build 체크 통과"
