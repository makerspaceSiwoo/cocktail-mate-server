# 복사해서 사용: cp terraform.tfvars.example terraform.tfvars
# terraform.tfvars 는 .gitignore 처리됨 (비밀값 포함, 커밋 금지).

# ---- OCI 인증 (콘솔 > 프로필 > API Keys 에서 확인/발급) ----
tenancy_ocid     = "ocid1.tenancy.oc1..xxxxxxxx"
user_ocid        = "ocid1.user.oc1..xxxxxxxx"
fingerprint      = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"
private_key_path = "~/.oci/oci_api_key.pem"
region           = "ap-chuncheon-1"

# 보통 테넌시 루트 컴파트먼트(=tenancy_ocid)를 그대로 사용해도 된다.
compartment_ocid = "ocid1.tenancy.oc1..xxxxxxxx"

# ---- 인스턴스 SSH 공개키 (cat ~/.ssh/id_rsa.pub 내용) ----
ssh_public_key = "ssh-rsa AAAA... user@host"

# ---- (선택) 컴퓨트 크기 / Ubuntu 버전 ----
# instance_ocpus      = 2
# instance_memory_gbs = 12
# ubuntu_version      = "24.04"

# ---- (선택) 버킷 이름 ----
# bucket_name = "cocktail-images"
